
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return signedIn() &&
        currentUserDoc().exists() &&
        currentUserDoc().data.role == 'admin';
    }

    // User Profiles: Only the owner can read/write their own profile
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId)
        && request.resource.data.role in ['user', 'driver']
        && request.resource.data.email == request.auth.token.email;
      allow update: if isOwner(userId)
        && (
          request.resource.data.role == resource.data.role ||
          isAdmin()
        );
    }
    
    // Buses: 
    // - Anyone authenticated can read active buses
    // - Only the driver (owner of the document) can update their own bus location
    match /buses/{busId} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == busId;
    }

    // Routes:
    // - Any signed-in user can read routes.
    // - Only admins can create, update or delete routes.
    match /routes/{routeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
  }
}
